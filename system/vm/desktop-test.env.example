# Copy this file to desktop-test.local.env and edit it for your machine.

LIBVIRT_URI="qemu:///system"
VM_NAME="config-desktop-test"
ISO_PATH=""
VCPUS="3"
RAM_MB="8192"
DISK_SIZE_GB="64"
NETWORK_NAME="default"
BOOT_FIRMWARE="uefi"
GRAPHICS="spice"
VIDEO_MODEL="virtio"
SNAPSHOT_NAME="fresh-install"

# Optional overrides:
# OSINFO_NAME="ubuntu24.04"
# DISK_PATH="/var/lib/libvirt/images/config-desktop-test.qcow2"
# VM_AUTOSTART="1"
